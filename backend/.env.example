# CodeGalaxy Backend - Environment Configuration Example
# Copy this file to .env and fill in the values

# GitHub Personal Access Token (for repository ingestion)
GITHUB_TOKEN=your_github_token_here

# Groq API Key (for AI summaries)
GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenRouter or OpenAI keys
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# Database URL
DATABASE_URL=sqlite+aiosqlite:///./codegalaxy.db
